{
  "id": "paloalto-traffic",
  "name": "Palo Alto Networks Traffic Log",
  "vendor": "Palo Alto Networks",
  "tool": "PAN-OS NGFW",
  "version": "1.0",

  "detection": {
    "sampleLines": 3,
    "required": [
      { "type": "csv_field_equals", "index": 3, "value": "TRAFFIC" }
    ],
    "optional": [
      { "type": "line_regex", "pattern": "^<\\d+>" }
    ]
  },

  "format": {
    "type": "csv",
    "hasHeader": false,
    "delimiter": ",",
    "stripSyslogPrefix": true,
    "syslogPrefixPattern": "^<\\d+>[A-Za-z]{3}\\s+\\d+\\s+[\\d:]+\\s+\\S+\\s+",
    "typeColumnIndex": 3,
    "headerVariants": {
      "TRAFFIC": [
        "future_use", "receive_time", "serial_number", "type", "threat_content_type",
        "future_use2", "generated_time", "src_ip", "dst_ip", "nat_src_ip", "nat_dst_ip",
        "rule_name", "src_user", "dst_user", "application", "virtual_system",
        "src_zone", "dst_zone", "ingress_interface", "egress_interface",
        "log_forwarding_profile", "future_use3", "session_id", "repeat_count",
        "src_port", "dst_port", "nat_src_port", "nat_dst_port", "flags",
        "protocol", "action", "bytes", "bytes_sent", "bytes_received",
        "packets", "start_time", "elapsed_time", "category", "future_use4",
        "sequence_number", "action_flags", "src_location", "dst_location",
        "future_use5", "packets_sent", "packets_received", "session_end_reason",
        "device_group_hierarchy_1", "device_group_hierarchy_2",
        "device_group_hierarchy_3", "device_group_hierarchy_4",
        "virtual_system_name", "device_name", "action_source",
        "src_uuid", "dst_uuid", "tunnel_id", "monitortag",
        "parent_session_id", "parent_start_time", "tunnel_type",
        "sctp_association_id", "sctp_chunks", "sctp_chunks_sent", "sctp_chunks_received"
      ],
      "THREAT": [
        "future_use", "receive_time", "serial_number", "type", "threat_content_type",
        "future_use2", "generated_time", "src_ip", "dst_ip", "nat_src_ip", "nat_dst_ip",
        "rule_name", "src_user", "dst_user", "application", "virtual_system",
        "src_zone", "dst_zone", "ingress_interface", "egress_interface",
        "log_forwarding_profile", "future_use3", "session_id", "repeat_count",
        "src_port", "dst_port", "nat_src_port", "nat_dst_port", "flags",
        "protocol", "action", "miscellaneous", "threat_id", "category",
        "severity", "direction", "sequence_number", "action_flags",
        "src_location", "dst_location", "content_type", "pcap_id",
        "file_digest", "cloud", "url_index", "user_agent", "file_type",
        "x_forwarded_for", "referrer", "sender", "subject", "recipient",
        "report_id", "device_group_hierarchy_1", "device_group_hierarchy_2",
        "device_group_hierarchy_3", "device_group_hierarchy_4",
        "virtual_system_name", "device_name", "future_use4",
        "src_uuid", "dst_uuid", "http_method", "tunnel_id", "monitortag",
        "parent_session_id", "parent_start_time", "tunnel_type",
        "threat_category", "content_version", "future_use5",
        "sctp_association_id", "payload_protocol_id",
        "http_headers", "url_category_list", "rule_uuid", "http2_connection"
      ]
    }
  },

  "columns": [
    { "key": "receive_time",  "label": "Receive Time",       "semantic": "timestamp", "required": true  },
    { "key": "src_ip",        "label": "Source IP",          "semantic": "src_ip",    "required": true  },
    { "key": "dst_ip",        "label": "Destination IP",     "semantic": "dst_ip",    "required": true  },
    { "key": "src_user",      "label": "Source User",        "semantic": "username",  "required": false },
    { "key": "rule_name",     "label": "Rule Name",                                   "required": false },
    { "key": "application",   "label": "Application",                                 "required": false },
    { "key": "src_zone",      "label": "Source Zone",                                 "required": false },
    { "key": "dst_zone",      "label": "Destination Zone",                            "required": false },
    { "key": "action",        "label": "Action",                                      "required": false },
    { "key": "protocol",      "label": "Protocol",                                    "required": false },
    { "key": "src_port",      "label": "Source Port",        "semantic": "src_port",  "required": false },
    { "key": "dst_port",      "label": "Destination Port",   "semantic": "dst_port",  "required": false },
    { "key": "bytes",         "label": "Total Bytes",                                 "required": false },
    { "key": "device_name",   "label": "Device Name",        "semantic": "hostname",  "required": false }
  ]
}
